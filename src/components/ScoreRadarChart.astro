---
const { scoreBreakdown = { features: 70, reviews: 70, momentum: 70, popularity: 70 } } = Astro.props;

const scores = Object.values(scoreBreakdown);
const labels = Object.keys(scoreBreakdown);
const cx = 100, cy = 100, r = 80;
const n = scores.length;

// Generate SVG elements
const gridRings = [1, 2, 3, 4].map(ring => {
  const ringR = r * ring / 4;
  const pts = [];
  for (let i = 0; i < n; i++) {
    const angle = (Math.PI * 2 * i / n) - Math.PI / 2;
    pts.push(`${cx + ringR * Math.cos(angle)},${cy + ringR * Math.sin(angle)}`);
  }
  return `<path d="M${pts.join('L')}Z" fill="none" stroke="var(--border)" stroke-width="0.5"/>`;
}).join('\n');

const axes = [];
for (let i = 0; i < n; i++) {
  const angle = (Math.PI * 2 * i / n) - Math.PI / 2;
  axes.push(`<path d="M${cx},${cy}L${cx + r * Math.cos(angle)},${cy + r * Math.sin(angle)}" fill="none" stroke="var(--border)" stroke-width="0.5"/>`);
}

const dataPoints = scores.map((val, i) => {
  const angle = (Math.PI * 2 * i / n) - Math.PI / 2;
  const radius = r * val / 100;
  return { x: cx + radius * Math.cos(angle), y: cy + radius * Math.sin(angle) };
});

const polyline = dataPoints.map((p, i) => `${i === 0 ? 'M' : 'L'}${p.x},${p.y}`).join(' ') + 'Z';

const dots = dataPoints.map(p => `<circle cx="${p.x}" cy="${p.y}" r="4" fill="var(--accent)"/>`).join('\n');

const labels_out = labels.map((label, i) => {
  const angle = (Math.PI * 2 * i / n) - Math.PI / 2;
  return `<text x="${cx + (r + 18) * Math.cos(angle)}" y="${cy + (r + 18) * Math.sin(angle)}" text-anchor="middle" dominant-baseline="middle" font-size="9" fill="var(--text-muted)" font-family="sans-serif">${label}</text>`;
}).join('\n');
---

<svg viewBox="0 0 200 200" style="width: 100%; max-width: 200px; margin: 0 auto; display: block;">
  {gridRings}
  {axes.join('\n')}
  <path d={polyline} fill="var(--accent)" fill-opacity="0.15" stroke="var(--accent)" stroke-width="2" />
  {dots}
  {labels_out}
</svg>
