---
import Base from '../layouts/Base.astro';
---

<Base title="Contact — AI Tools Nav" description="Get in touch with the AI Tools Nav team. Questions, suggestions, or tool recommendations — we'd love to hear from you.">
  <div class="container" style="padding-top: 32px; max-width: 740px; margin: 40px auto;">
    <h1 class="page-title">Contact Us</h1>
    
    <section style="margin: 32px 0;">
      <p style="font-size: 1.05rem; color: var(--text-secondary); line-height: 1.7; margin-bottom: 16px;">
        Have a question, suggestion, or tool recommendation? We'd love to hear from you. 
        Our team reads every message and strives to respond within <strong>2 business days</strong>.
      </p>
    </section>

    <section style="margin: 32px 0; padding: 32px; border: 1px solid var(--border); border-radius: 12px; background: var(--bg-subtle);">
      <h2 style="font-size: 1.15rem; font-weight: 700; margin-bottom: 16px;">📧 Email</h2>
      <p style="font-size: 1rem; color: var(--text-secondary); line-height: 1.6;">
        Send us an email at <a href="mailto:hello@aitoolsnav.net" style="font-weight: 600; font-size: 1.1rem;">hello@aitoolsnav.net</a>
      </p>
      <p style="font-size: 0.875rem; color: var(--text-muted); margin-top: 8px;">
        For general inquiries, feedback, and tool suggestions.
      </p>
    </section>

    <section style="margin: 32px 0; padding: 32px; border: 1px solid var(--border); border-radius: 12px; background: var(--bg-subtle);">
      <h2 style="font-size: 1.15rem; font-weight: 700; margin-bottom: 16px;">🔒 Privacy Inquiries</h2>
      <p style="font-size: 1rem; color: var(--text-secondary); line-height: 1.6;">
        For privacy-related requests, contact <a href="mailto:privacy@aitoolsnav.net" style="font-weight: 600;">privacy@aitoolsnav.net</a>
      </p>
    </section>

    <section style="margin: 32px 0; padding: 32px; border: 1px solid var(--border); border-radius: 12px; background: var(--bg-subtle);">
      <h2 style="font-size: 1.15rem; font-weight: 700; margin-bottom: 16px;">🤝 Partnerships &amp; Advertising</h2>
      <p style="font-size: 1rem; color: var(--text-secondary); line-height: 1.6;">
        Interested in partnering with AI Tools Nav? Reach out at <a href="mailto:hello@aitoolsnav.net" style="font-weight: 600;">hello@aitoolsnav.net</a>
      </p>
    </section>
  </div>
</Base>
