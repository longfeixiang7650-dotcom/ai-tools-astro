---
import Base from '../layouts/Base.astro';
---

<Base title="Affiliate Disclosure — AI Tools Nav">
  <div class="container" style="padding-top: 32px; max-width: 740px; margin: 40px auto;">
    <h1 class="page-title">Affiliate Disclosure</h1>

    <section style="margin: 32px 0; color: var(--text-secondary); line-height: 1.7;">
      <p style="margin-bottom: 16px;"><strong>AI Tools Nav is committed to transparency.</strong> Here's how our reviews and recommendations work:</p>

      <ul style="padding-left: 20px; line-height: 1.8; margin-bottom: 16px;">
        <li><strong>Independent reviews.</strong> All tool listings and reviews on AI Tools Nav are independently compiled. No tool can pay for placement or rating.</li>
        <li><strong>Ratings.</strong> Our ratings are based on publicly available information, editorial research, and aggregated user feedback from multiple sources.</li>
        <li><strong>No sponsored content.</strong> We do not accept payment for reviews, rankings, or editorial coverage.</li>
        <li><strong>Third-party ads.</strong> If and when we display advertising, it will be managed by third-party ad networks and clearly marked as such.</li>
      </ul>

      <p>If you have questions, contact <a href="mailto:hello@aitoolsnav.net">hello@aitoolsnav.net</a>.</p>
    </section>
  </div>
</Base>
