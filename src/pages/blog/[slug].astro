---
import Base from '../../layouts/Base.astro';
import { BLOG_POSTS } from '../../data/blog-posts';
import { ALL_TOOLS } from '../../data/tools';

export function getStaticPaths() {
  return BLOG_POSTS.map(post => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const relatedPosts = BLOG_POSTS
  .filter(p => p.category === post.category && p.slug !== post.slug)
  .slice(0, 3);

function renderContent(content: string): string {
  return content.split('\n').map(line => {
    line = line.trim();
    if (!line) return '';

    if (line.startsWith('#### '))
      return `<h4>${line.slice(5)}</h4>`;
    if (line.startsWith('### '))
      return `<h3>${line.slice(4)}</h3>`;
    if (line.startsWith('## '))
      return `<h2>${line.slice(3)}</h2>`;
    if (line.startsWith('# '))
      return `<h1>${line.slice(2)}</h1>`;
    if (line.startsWith('###'))
      return `<h3>${line.slice(3)}</h3>`;
    if (line.startsWith('##'))
      return `<h2>${line.slice(2)}</h2>`;
    if (line.startsWith('- '))
      return `<li>${line.slice(2)}</li>`;
    if (line.startsWith('|'))
      return '';
    if (line.startsWith('**') && line.endsWith('**'))
      return `<p><strong>${line.slice(2, -2)}</strong></p>`;

    return `<p>${line}</p>`;
  }).filter(Boolean).join('\n');
}
---

<Base title={`${post.title} — AI Tools Nav Blog`} description={post.excerpt?.slice(0, 160)}>
  <div class="container" style="padding-top: 32px;">
    <div class="blog-article">
      <!-- Breadcrumb -->
      <div class="breadcrumb">
        <a href="/">Home</a>
        <span>›</span>
        <a href="/blog">Blog</a>
        <span>›</span>
        <span>{post.title.slice(0, 60)}...</span>
      </div>

      <!-- Article Header -->
      <header style="margin-bottom: 32px; padding-bottom: 24px; border-bottom: 1px solid var(--border);">
        <div style="display: flex; gap: 8px; align-items: center; margin-bottom: 12px; flex-wrap: wrap;">
          <span class="tag" style="background: var(--accent-light); color: var(--accent); font-weight: 600;">{post.category}</span>
          <span style="font-size: 0.8125rem; color: var(--text-muted);">{post.date}</span>
          <span style="font-size: 0.8125rem; color: var(--text-muted);">·</span>
          <span style="font-size: 0.8125rem; color: var(--text-muted);">{post.readTime} min read</span>
        </div>
        <h1 class="page-title" style="font-size: 2rem; margin-bottom: 12px;">{post.title}</h1>
        <div style="display: flex; align-items: center; gap: 10px;">
          <div style="width: 36px; height: 36px; border-radius: 50%; background: var(--accent); color: white; display: flex; align-items: center; justify-content: center; font-size: 0.8125rem; font-weight: 700;">
            {post.author?.split(' ').map(n => n[0]).join('')}
          </div>
          <div>
            <div style="font-size: 0.875rem; font-weight: 600;">{post.author}</div>
            <div style="font-size: 0.75rem; color: var(--text-muted);">{post.authorRole}</div>
          </div>
        </div>
        <div style="margin-top: 12px; display: flex; gap: 6px; flex-wrap: wrap;">
          {(post.tags || []).map(tag => (
            <span class="tag">{tag}</span>
          ))}
        </div>
        <p style="margin-top: 16px; font-size: 1.05rem; color: var(--text-secondary); line-height: 1.6; border-left: 3px solid var(--accent); padding-left: 16px;">
          {post.excerpt}
        </p>
      </header>

      <!-- Article Content -->
      <article style="line-height: 1.8; color: var(--text-secondary); font-size: 1rem;" set:html={renderContent(post.content)} />

      <!-- Share / Footer -->
      <div style="margin-top: 40px; padding-top: 24px; border-top: 1px solid var(--border);">
        <p style="font-size: 0.8125rem; color: var(--text-muted);">
          📌 Published by <strong>{post.author}</strong> ({post.authorRole}) on {post.date}.
          All reviews reflect honest evaluations. 
          See our <a href="/disclosure">disclosure policy</a>.
        </p>
      </div>

      <!-- Related Posts -->
      {relatedPosts.length > 0 && (
        <section style="margin-top: 48px; padding-top: 32px; border-top: 1px solid var(--border);">
          <h2 style="font-size: 1.25rem; font-weight: 700; margin-bottom: 16px;">Related Articles</h2>
          <div style="display: flex; flex-direction: column; gap: 12px;">
            {relatedPosts.map(rp => (
              <a href={`/blog/${rp.slug}`} style="display: block; padding: 16px 20px; border: 1px solid var(--border); border-radius: 8px; text-decoration: none; color: inherit;">
                <div style="font-size: 0.8125rem; color: var(--text-muted); margin-bottom: 4px;">{rp.date} · {rp.readTime} min read</div>
                <div style="font-weight: 600;">{rp.title}</div>
              </a>
            ))}
          </div>
        </section>
      )}
    </div>
  </div>
</Base>
