---
import Base from '../../layouts/Base.astro';
import { BLOG_POSTS } from '../../data/blog-posts';

const sortedPosts = [...BLOG_POSTS].sort(
  (a, b) => new Date(b.date).getTime() - new Date(a.date).getTime()
);

const allCategories = [...new Set(BLOG_POSTS.map(p => p.category))];
const allTags = [...new Set(BLOG_POSTS.flatMap(p => p.tags || []))].slice(0, 15);
---

<Base title="AI Tools Blog — AI Tools Nav" description="In-depth articles, comparisons, and guides about AI tools, LLMs, and AI workflows.">
  <div class="container" style="padding-top: 32px;">
    <h1 class="page-title">Blog</h1>
    <p class="page-subtitle">In-depth AI tool reviews, comparisons, and industry analysis. {BLOG_POSTS.length} articles.</p>

    <div style="display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 32px; padding-bottom: 20px; border-bottom: 1px solid var(--border);">
      <span class="tag" style="background: var(--accent); color: white;">All Posts</span>
      {allCategories.slice(0, 8).map(cat => (
        <span class="tag">{cat}</span>
      ))}
    </div>

    <div style="display: flex; flex-direction: column; gap: 12px;">
      {sortedPosts.map(post => (
        <a href={`/blog/${post.slug}`} style="display: grid; grid-template-columns: 1fr auto; gap: 24px; padding: 24px; border: 1px solid var(--border); border-radius: 8px; text-decoration: none; color: inherit; transition: border-color 0.15s, box-shadow 0.15s;">
          <div>
            <div class="card-meta" style="margin-bottom: 6px;">
              <span class="tag">{post.category}</span>
              <span style="margin-left: 8px; color: var(--text-muted);">{post.date}</span>
              <span style="color: var(--text-muted);"> · {post.readTime} min read</span>
            </div>
            <h2 style="font-size: 1.25rem; font-weight: 700; margin-bottom: 8px; line-height: 1.3;">
              {post.title}
            </h2>
            <p style="font-size: 0.875rem; color: var(--text-secondary); line-height: 1.6;">
              {post.excerpt?.slice(0, 250)}...
            </p>
            <div style="margin-top: 12px; display: flex; gap: 6px; flex-wrap: wrap;">
              {(post.tags || []).slice(0, 4).map(tag => (
                <span class="tag">{tag}</span>
              ))}
            </div>
          </div>
          <div style="display: flex; flex-direction: column; justify-content: center; align-items: flex-end; min-width: 80px;">
            <div style="font-size: 0.875rem; color: var(--accent); font-weight: 600;">
              Read →
            </div>
          </div>
        </a>
      ))}
    </div>
  </div>
</Base>
