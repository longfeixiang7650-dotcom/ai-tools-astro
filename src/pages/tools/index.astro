---
import Base from '../../layouts/Base.astro';
import { ALL_TOOLS } from '../../data/tools';

const categories = [...new Set(ALL_TOOLS.map(t => t.category))];
---

<Base title="All AI Tools — AI Tools Nav" description="Browse our complete collection of AI tool reviews. ChatGPT, Claude, Midjourney, GitHub Copilot, and more.">
  <div class="container" style="padding-top: 32px;">
    <h1 class="page-title">All AI Tools</h1>
    <p class="page-subtitle">{ALL_TOOLS.length} AI tools reviewed by practitioners</p>

    <!-- Category filters -->
    <div style="display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 32px; padding-bottom: 20px; border-bottom: 1px solid var(--border);">
      <span class="tag" style="background: var(--accent); color: white; padding: 6px 14px; cursor: default;">All</span>
      {categories.map(cat => (
        <a href={`/category/${cat.toLowerCase().replace(/[\/\s]+/g, '-')}`} class="tag" style="padding: 6px 14px; text-decoration: none;">
          {cat}
        </a>
      ))}
    </div>

    <!-- Tools Grid -->
    <div class="tools-grid">
      {ALL_TOOLS.map(tool => (
        <a href={`/tools/${tool.id}`} class="card" style="text-decoration: none; color: inherit; display: block;">
          <div style="display: flex; justify-content: space-between; align-items: start; margin-bottom: 8px;">
            <div style="display: flex; align-items: center; gap: 10px;">
              <span style="font-size: 1.5rem;">{tool.icon || '🤖'}</span>
              <div>
                <div class="card-title">{tool.name}</div>
                <div style="font-size: 0.75rem; color: var(--text-muted); margin-top: 2px;">{tool.category}</div>
              </div>
            </div>
            <div style="text-align: right;">
              <div style="font-weight: 700; color: var(--accent); font-size: 1.125rem;">{tool.rating}</div>
              <div style="font-size: 0.6875rem; color: var(--text-muted);">{tool.reviewCount.toLocaleString()} reviews</div>
            </div>
          </div>
          <p style="font-size: 0.875rem; color: var(--text-secondary); line-height: 1.5; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;">
            {tool.description}
          </p>
          <div style="margin-top: 10px; display: flex; gap: 4px; flex-wrap: wrap;">
            {(tool.features || []).slice(0, 3).map(f => (
              <span class="tag">{f}</span>
            ))}
          </div>
          <div style="margin-top: 12px; font-size: 0.75rem; color: var(--text-muted);">
            {tool.pricing} · <span style="color: var(--accent);">Read review →</span>
          </div>
        </a>
      ))}
    </div>
  </div>
</Base>
