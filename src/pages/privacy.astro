---
import Base from '../layouts/Base.astro';
---

<Base title="Privacy Policy — AI Tools Nav">
  <div class="container" style="padding-top: 32px; max-width: 740px; margin: 40px auto;">
    <h1 class="page-title">Privacy Policy</h1>
    <p style="font-size: 0.875rem; color: var(--text-muted); margin-bottom: 32px;">Last updated: June 2026</p>

    <section style="margin-bottom: 24px; color: var(--text-secondary); line-height: 1.7;">
      <h2 style="font-size: 1.1rem; font-weight: 700; margin-bottom: 8px; color: var(--text);">1. Information We Collect</h2>
      <p>AI Tools Nav does not collect personal information beyond standard web analytics. We use minimal cookies for site functionality. Third-party services (Google AdSense, Cloudflare) may collect anonymized data per their privacy policies.</p>
    </section>

    <section style="margin-bottom: 24px; color: var(--text-secondary); line-height: 1.7;">
      <h2 style="font-size: 1.1rem; font-weight: 700; margin-bottom: 8px; color: var(--text);">2. Cookies</h2>
      <p>We use essential cookies for site security (Cloudflare) and optional cookies for analytics. You can manage cookie preferences through our cookie banner. We do not use tracking cookies for advertising personalization.</p>
    </section>

    <section style="margin-bottom: 24px; color: var(--text-secondary); line-height: 1.7;">
      <h2 style="font-size: 1.1rem; font-weight: 700; margin-bottom: 8px; color: var(--text);">3. Third-Party Services</h2>
      <p>AI Tools Nav uses the following third-party services: Google AdSense (ads), Cloudflare (CDN and security). Each service operates under its own privacy policy.</p>
    </section>

    <section style="margin-bottom: 24px; color: var(--text-secondary); line-height: 1.7;">
      <h2 style="font-size: 1.1rem; font-weight: 700; margin-bottom: 8px; color: var(--text);">4. Contact</h2>
      <p>Privacy inquiries: <a href="mailto:privacy@aitoolsnav.net">privacy@aitoolsnav.net</a></p>
    </section>
  </div>
</Base>
