---
import '../styles/global.css';
const { title, description } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title ? `${title} — AI Tools Nav` : 'AI Tools Nav — Honest AI Tool Reviews'}</title>
    <meta name="description" content={description || 'Hands-on reviews of the best AI tools. ChatGPT, Claude, GitHub Copilot, Midjourney and more — tested and honestly reviewed.'} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body>
    <header class="site-header">
      <div class="header-inner">
        <a href="/" class="site-logo"><span>AI Tools</span> Nav</a>
        <nav class="main-nav">
          <a href="/" class="active">Home</a>
          <a href="/tools">Tools</a>
          <a href="/blog">Blog</a>
          <a href="/about">About</a>
        </nav>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <div class="footer-inner">
        <span>&copy; {new Date().getFullYear()} AI Tools Nav. Independent AI tool reviews.</span>
        <div class="footer-links">
          <a href="/about">About</a>
          <a href="/privacy">Privacy</a>
          <a href="/terms">Terms</a>
          <a href="/disclosure">Disclosure</a>
        </div>
      </div>
    </footer>
  </body>
</html>
